---
import Layout from "@/layouts/Layout.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";

const sections = [
  {
    title: "Why students join",
    body: "Students join Symphonic Student Association at UCSD because they want an ensemble-focused student organization where they can rehearse, perform, and meet other people who care about classical music. Some members are experienced performers, some want a musical outlet outside coursework, and others are looking for a welcoming campus community.",
  },
  {
    title: "What we offer",
    body: "SSA at UCSD offers ensemble participation, weekly rehearsals, concerts, student-led performances, and community events that make it easier to stay connected to music while balancing the rest of campus life. The organization is designed to be accessible to students across majors and musical backgrounds.",
  },
  {
    title: "Concerts, rehearsals, and socials",
    body: "Our calendar includes rehearsals, performances, social gatherings, and trips that help members stay active in the organization throughout the year. Whether you want to perform regularly or meet people who care about orchestral and chamber repertoire, Symphonic Student Association at UCSD offers a clear point of entry.",
  },
  {
    title: "How to join Symphonic Student Association at UCSD",
    body: "If you are searching for a classical music club at UCSD, Symphonic Student Association at UCSD is a student-run organization you can join. Create an account through the membership portal, read more about the organization, and check upcoming events to see what is happening next.",
  },
];
---

<Layout
  title="Classical Music Club at UCSD | Symphonic Student Association at UCSD"
  description="Looking for a classical music club at UCSD? Learn about the Symphonic Student Association at UCSD, our rehearsals, performances, and how to get involved."
>
  <section class="w-full bg-background px-6 py-16 md:py-24">
    <div class="mx-auto flex max-w-5xl flex-col gap-12">
      <div class="flex flex-col gap-5">
        <Breadcrumb items={[{ name: "Classical Music Club at UCSD" }]} />
        <p class="text-sm font-bold uppercase tracking-[0.3em] text-primary">
          Symphonic Student Association at UCSD
        </p>
        <h1 class="text-5xl font-black">Classical Music Club at UCSD</h1>
        <p class="text-lg text-muted-foreground">
          Symphonic Student Association at UCSD is a student-run classical music club at UC San
          Diego focused on ensemble playing, rehearsals, performances, and community. We are an
          organization for students who want a welcoming way to stay involved with classical music
          through campus life.
        </p>
        <p class="text-lg text-muted-foreground">
          If you want to learn more about{" "}
          <a
            href="/"
            class="font-semibold text-primary underline decoration-primary/40 underline-offset-4"
          >
            Symphonic Student Association at UCSD
          </a>
          , explore our{" "}
          <a
            href="/events"
            class="font-semibold text-primary underline decoration-primary/40 underline-offset-4"
          >
            classical music events at UCSD
          </a>
          , or read{" "}
          <a
            href="/about"
            class="font-semibold text-primary underline decoration-primary/40 underline-offset-4"
          >
            about the Symphonic Student Association at UCSD
          </a>
          .
        </p>
      </div>

      <div class="grid gap-6">
        {sections.map(({ title, body }) => (
          <section class="rounded-2xl border border-border bg-card p-8 shadow-sm">
            <h2 class="text-3xl font-bold">{title}</h2>
            <p class="mt-4 text-lg text-muted-foreground">{body}</p>
          </section>
        ))}
      </div>

      <section class="rounded-2xl border border-primary/15 bg-primary/5 p-8">
        <h2 class="text-3xl font-bold">Get involved</h2>
        <p class="mt-4 text-lg text-muted-foreground">
          Join Symphonic Student Association at UCSD through the{" "}
          <a
            href="https://members.ssaucsd.org"
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold text-primary underline decoration-primary/40 underline-offset-4"
          >
            membership portal
          </a>
          , follow us on{" "}
          <a
            href="https://www.instagram.com/ssa_at_ucsd"
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold text-primary underline decoration-primary/40 underline-offset-4"
          >
            Instagram
          </a>
          , or connect on{" "}
          <a
            href="https://discord.gg/PncDrAxvkS"
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold text-primary underline decoration-primary/40 underline-offset-4"
          >
            Discord
          </a>
          .
        </p>
      </section>
    </div>
  </section>
</Layout>
