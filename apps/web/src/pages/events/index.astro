---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import EventCard from "@/components/EventCard.astro";
import { getAllEvents } from "@/lib/events";

const events = await getAllEvents();

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=900, stale-while-revalidate=3600",
);
---

<Layout
  title="Classical Music Events at UCSD | Symphonic Student Association at UCSD"
  description="Explore upcoming classical music events at UCSD hosted by the Symphonic Student Association at UCSD, including concerts, rehearsals, recitals, and socials."
>
  <div class="w-full py-12 md:py-24 px-6 bg-background">
    <div class="w-3/4 mx-auto flex flex-col gap-16">
      <div class="flex flex-col gap-4 items-start text-left">
        <Breadcrumb items={[{ name: "Events" }]} className="mb-2" />
        <h1 class="text-5xl font-black">Classical Music Events at UCSD</h1>
        <p class="text-xl text-muted-foreground max-w-2xl">
          Explore concerts, rehearsals, and socials hosted by the Symphonic Student Association at
          UCSD, and learn more about{" "}
          <a
            href="/classical-music-club-at-ucsd"
            class="font-semibold text-primary underline decoration-primary/40 underline-offset-4"
          >
            Symphonic Student Association at UCSD
          </a>
          .
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
        {events.length === 0 ? (
          <div class="col-span-full flex flex-col items-center justify-center gap-4 py-12 text-muted-foreground">
            <p class="text-xl font-medium">No upcoming events :(</p>
          </div>
        ) : (
          events.map((event) => (
            <EventCard {...event} />
          ))
        )}
      </div>
    </div>
  </div>
</Layout>
